
# Main app domain
ONE_SERVER_URL=https://your-domain.com
BETTER_AUTH_URL=https://your-domain.com

# Zero sync server hostname (no protocol)
VITE_ZERO_HOSTNAME=zero.your-domain.com
VITE_WEB_HOSTNAME=your-domain.com

# Zero sync databases (derived from DEPLOY_DB host, different db names)
# Zero requires 3 databases on the same host:
#   - Main database (your app data)
#   - zero_cvr (client view records)
#   - zero_cdb (change database)
ZERO_UPSTREAM_DB=postgresql://user:password@host:5432/postgres?sslmode=require
ZERO_CVR_DB=postgresql://user:password@host:5432/zero_cvr?sslmode=require
ZERO_CHANGE_DB=postgresql://user:password@host:5432/zero_cdb?sslmode=require

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-here

# ============================================================================
# CHURCH APP — client bundle (Vite exposes VITE_* to import.meta.env)
# ============================================================================

VITE_CHURCH_DISPLAY_NAME=Stroudsburg Wesleyan Church

# Give tab — same URL as ENGAGE_GIVE_URL; required for the center Give button
VITE_ENGAGE_GIVE_URL=https://engage.suran.com/stroudsburg/s/give/gift/all-giving

# YouTube Data API v3 (Ticket 02) — restrict key in Google Cloud Console
VITE_YOUTUBE_API_KEY=
# Stroudsburg Wesleyan Church (handle @stroudsburgwesleyanchurch8704)
VITE_YOUTUBE_CHANNEL_ID=UCNHOf9LGimGtBWO8XLCqO6g

# WordPress REST (Tickets 03–04) — public read; base ${VITE_WORDPRESS_ORIGIN}/wp-json/wp/v2
VITE_WORDPRESS_ORIGIN=https://www.stroudsburgwesleyan.org
VITE_WORDPRESS_EVENTS_PAGE_ID=3117
# VITE_WORDPRESS_ABOUT_PAGE_ID=
# VITE_WORDPRESS_ABOUT_PAGE_SLUG=

# ============================================================================
# CHURCH APP — optional non-VITE aliases (scripts, server tooling)
# ============================================================================

YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=UCNHOf9LGimGtBWO8XLCqO6g

WORDPRESS_ORIGIN=https://www.stroudsburgwesleyan.org
WORDPRESS_EVENTS_PAGE_ID=3117
WORDPRESS_HOME_PAGE_ID=2403
